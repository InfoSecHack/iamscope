  "family": "multihop_chain_validated",
  "tier": "tier1_live_aws",
  "purpose": "Prove IAMScope validates one controlled same-account 3-hop AssumeRole chain to an admin-equivalent role.",
  "claim_surface": [
    "IAMScope can collect exact same-account sts:AssumeRole permission edges for all three Env26 hops.",
    "IAMScope can collect exact same-account sts:AssumeRole trust edges for all three Env26 hops.",
    "IAMScope can compose the three-hop Alice-to-admin path in assume_role_chain.",
    "IAMScope can emit validated admin_reachability for Alice through the three-hop path.",
    "IAMScope can keep the target path free of blocked, inconclusive, or blocker-bearing validated findings."
  ],
  "benchmark_proves": [
    "The Env26 Alice, hop1, hop2, and admin IAM nodes exist structurally.",
    "The exact Env26 Alice-to-hop1 permission and trust edges exist.",
    "The exact Env26 hop1-to-hop2 permission and trust edges exist.",
    "The exact Env26 hop2-to-admin permission and trust edges exist.",
    "The exact Env26 Alice-to-admin target path is emitted as validated assume_role_chain.",
    "The exact Env26 Alice-to-admin target path is emitted as validated admin_reachability.",
    "The target path is not emitted as blocked or inconclusive."
  ],
  "benchmark_does_not_prove": [
    "It does not prove arbitrary enterprise graph correctness.",
    "It does not prove chains deeper than the current reasoner depth cap.",
    "It does not prove cross-account multi-hop behavior.",
    "It does not prove SCP, permission-boundary, identity Deny, or condition handling.",
    "It does not prove runtime exploitability.",
    "It does not prove production readiness."
  ],
  "unknowns_remaining": [
    "Env27 should test the scoped-away middle-trust mutation.",
    "Cross-account multi-hop chains remain outside this case.",
    "Longer chains and conditioned middle-hop controls remain outside this case."
  ],
  "environment": {
    "acceptance_env": "acceptance/env26_multihop_chain_validated",
    "benchmark_family": "controlled_live_aws",
    "notes": "Single-account IAM-only positive 3-hop AssumeRole chain. No SCPs, boundaries, Denies, or conditions are created."
  },
  "ground_truth": {
    "reachable": true,
    "admin_equivalent": true,
    "chain_hops": 3,
    "reason": "Env26 Alice can assume hop1, hop1 can assume hop2, hop2 can assume env26-admin, and every hop has exact trust plus exact permission. The final role has AdministratorAccess."
  },
