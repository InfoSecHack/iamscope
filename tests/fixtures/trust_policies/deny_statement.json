{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Deny",
      "Principal": {
        "AWS": "*"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringNotEquals": {
          "aws:PrincipalOrgID": "o-myorg123"
        }
      }
    },
    {
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::222222\u003222222:role/AllowedRole"
      },
      "Action": "sts:AssumeRole"
    }
  ]
}
