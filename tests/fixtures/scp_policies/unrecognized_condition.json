{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyWithTagCondition",
      "Effect": "Deny",
      "Action": "sts:AssumeRole",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/Environment": "production"
        },
        "ArnNotLike": {
          "aws:PrincipalArn": "arn:aws:iam::*:role/BreakGlass*"
        }
      }
    }
  ]
}
