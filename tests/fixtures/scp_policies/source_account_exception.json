{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyExternalAccounts",
      "Effect": "Deny",
      "Action": "sts:AssumeRole",
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:SourceAccount": [
            "111111111111",
            "222222222222"
          ]
        }
      }
    }
  ]
}
