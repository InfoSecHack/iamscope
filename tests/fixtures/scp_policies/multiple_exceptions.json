{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyAssumeRoleMultiException",
      "Effect": "Deny",
      "Action": [
        "sts:AssumeRole",
        "sts:AssumeRoleWithSAML",
        "sts:AssumeRoleWithWebIdentity"
      ],
      "Resource": "*",
      "Condition": {
        "ArnNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/BreakGlass*",
            "arn:aws:iam::*:role/OrganizationAccountAccessRole",
            "arn:aws:iam::*:role/Admin*"
          ]
        }
      }
    }
  ]
}
